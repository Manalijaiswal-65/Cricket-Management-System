});

// ==================== TOURNAMENT ROUTES ====================

// Get all tournaments
app.get('/api/tournaments', async (req, res) => {
  try {
    const { status, sport_type } = req.query;
    const query = {};
    if (status) query.status = status;
    if (sport_type) query.sport_type = sport_type;

    const tournaments = await Tournament.find(query).sort({ created_at: -1 }).select('-_id -__v');
    res.json(tournaments);
  } catch (error) {
    res.status(500).json({ detail: 'Failed to fetch tournaments' });
  }
});

// Get tournament by ID
app.get('/api/tournaments/:tournamentId', async (req, res) => {
  try {
    const tournament = await Tournament.findOne({ tournament_id: req.params.tournamentId }).select('-_id -__v');
    if (!tournament) return res.status(404).json({ detail: 'Tournament not found' });

    // Get all matches for this tournament
    const matches = await TournamentMatch.find({ tournament_id: req.params.tournamentId })
      .sort({ round: 1, match_number: 1 })
      .select('-_id -__v');

    // Get team details
    const teamIds = tournament.teams || [];
    const teams = await Team.find({ team_id: { $in: teamIds } }).select('-_id -__v');

    res.json({
      ...tournament.toObject(),
      matches,
      team_details: teams
    });
  } catch (error) {
    res.status(500).json({ detail: 'Failed to fetch tournament' });
  }
});

// Create tournament (Manager only)
app.post('/api/tournaments', authenticate, requireManagerOrAdmin, async (req, res) => {
  try {
    const { name, sport_type, format, teams, venue, overs, start_date, match_interval_hours } = req.body;

    const tournament_id = `tourn_${uuidv4().slice(0, 8)}`;

    const tournament = new Tournament({
      tournament_id,
      name,
      sport_type: sport_type || 'cricket',
      format: format || 'knockout',
      teams: teams || [],
      venue,
      overs: overs || 20,
      start_date: start_date ? new Date(start_date) : null,
      match_interval_hours: match_interval_hours || 24,
      created_by: req.user.user_id,
      status: 'draft',
      created_at: new Date()
    });

    await tournament.save();
    res.json(tournament.toObject({ versionKey: false }));
  } catch (error) {
    console.error('Create tournament error:', error);
    res.status(500).json({ detail: 'Failed to create tournament' });
  }
});

// Update tournament
app.put('/api/tournaments/:tournamentId', authenticate, requireManagerOrAdmin, async (req, res) => {
  try {
    const tournament = await Tournament.findOne({ tournament_id: req.params.tournamentId });
    if (!tournament) return res.status(404).json({ detail: 'Tournament not found' });

    if (req.user.role === 'manager' && tournament.created_by !== req.user.user_id) {
      return res.status(403).json({ detail: 'Can only update your own tournaments' });
    }

    const updated = await Tournament.findOneAndUpdate(
      { tournament_id: req.params.tournamentId },
      { $set: req.body },
      { new: true }
    ).select('-_id -__v');

    res.json(updated);
  } catch (error) {
    res.status(500).json({ detail: 'Failed to update tournament' });
  }
});

// Add team to tournament
app.post('/api/tournaments/:tournamentId/teams', authenticate, requireManagerOrAdmin, async (req, res) => {
  try {
    const { team_id } = req.body;
    const tournament = await Tournament.findOne({ tournament_id: req.params.tournamentId });

    if (!tournament) return res.status(404).json({ detail: 'Tournament not found' });
    if (tournament.status !== 'draft') {
      return res.status(400).json({ detail: 'Cannot add teams to started tournament' });
    }

    if (!tournament.teams.includes(team_id)) {
      tournament.teams.push(team_id);
      await tournament.save();
    }

    res.json(tournament.toObject({ versionKey: false }));
  } catch (error) {
    res.status(500).json({ detail: 'Failed to add team' });
  }
});

// Remove team from tournament
app.delete('/api/tournaments/:tournamentId/teams/:teamId', authenticate, requireManagerOrAdmin, async (req, res) => {
  try {
    const tournament = await Tournament.findOne({ tournament_id: req.params.tournamentId });

    if (!tournament) return res.status(404).json({ detail: 'Tournament not found' });
    if (tournament.status !== 'draft') {
      return res.status(400).json({ detail: 'Cannot remove teams from started tournament' });
    }

    tournament.teams = tournament.teams.filter(t => t !== req.params.teamId);
    await tournament.save();

    res.json(tournament.toObject({ versionKey: false }));
  } catch (error) {
    res.status(500).json({ detail: 'Failed to remove team' });
  }
});

// Generate bracket and start tournament
app.post('/api/tournaments/:tournamentId/generate-bracket', authenticate, requireManagerOrAdmin, async (req, res) => {
  try {
    const tournament = await Tournament.findOne({ tournament_id: req.params.tournamentId });

    if (!tournament) return res.status(404).json({ detail: 'Tournament not found' });
    if (tournament.teams.length < 2) {
      return res.status(400).json({ detail: 'Need at least 2 teams' });
    }

    const numTeams = tournament.teams.length;
    const rounds = Math.ceil(Math.log2(numTeams));
    const bracketSize = Math.pow(2, rounds);

    // Shuffle teams
    const shuffledTeams = [...tournament.teams].sort(() => Math.random() - 0.5);

    // Pad with byes if needed
    while (shuffledTeams.length < bracketSize) {
      shuffledTeams.push(null);
    }

    // Create bracket structure
    const bracket = {
      rounds,
      bracket_size: bracketSize,
      teams: shuffledTeams
    };

    // Generate first round matches
    const matches = [];
    const startDate = tournament.start_date || new Date();
    let matchDate = new Date(startDate);

    for (let i = 0; i < bracketSize / 2; i++) {
      const team1 = shuffledTeams[i * 2];
      const team2 = shuffledTeams[i * 2 + 1];

      const match_id = `match_${uuidv4().slice(0, 8)}`;
      const match = {
        match_id,
        tournament_id: tournament.tournament_id,
        round: 1,
        match_number: i + 1,
        team1_id: team1,
        team2_id: team2,
        venue: tournament.venue,
        match_date: new Date(matchDate),
        overs: tournament.overs,
        match_type: tournament.overs === 20 ? 'T20' : tournament.overs === 50 ? 'ODI' : 'Custom',
        status: team1 && team2 ? 'scheduled' : 'completed',
        bracket_position: rounds === 1 ? 'F' : rounds === 2 ? `SF${i + 1}` : rounds === 3 ? `QF${i + 1}` : `R1M${i + 1}`,
        created_at: new Date()
      };

      // If one team is bye, auto-advance
      if (!team1 && team2) {
        match.winner_id = team2;
        match.result_summary = `${team2} advances (Bye)`;
      } else if (team1 && !team2) {
        match.winner_id = team1;
        match.result_summary = `${team1} advances (Bye)`;
      }

      matches.push(match);
      matchDate = new Date(matchDate.getTime() + tournament.match_interval_hours * 60 * 60 * 1000);
    }

    // Create placeholder matches for subsequent rounds
    for (let round = 2; round <= rounds; round++) {
      const matchesInRound = Math.pow(2, rounds - round);
      for (let i = 0; i < matchesInRound; i++) {
        const match_id = `match_${uuidv4().slice(0, 8)}`;
        matches.push({
          match_id,
          tournament_id: tournament.tournament_id,
          round,
          match_number: i + 1,
          team1_id: null,
          team2_id: null,
          venue: tournament.venue,
          match_date: new Date(matchDate),
          overs: tournament.overs,
          match_type: tournament.overs === 20 ? 'T20' : 'ODI',
          status: 'pending',
          bracket_position: round === rounds ? 'F' : round === rounds - 1 ? `SF${i + 1}` : `R${round}M${i + 1}`,
          created_at: new Date()
        });
        matchDate = new Date(matchDate.getTime() + tournament.match_interval_hours * 60 * 60 * 1000);
      }
    }

    // Save matches
    await TournamentMatch.insertMany(matches);

    // Update tournament
    tournament.bracket_data = bracket;
    tournament.status = 'upcoming';
    await tournament.save();

    broadcastTournamentUpdate(tournament.tournament_id, { type: 'bracket_generated', tournament });

    res.json({
      message: 'Bracket generated successfully',
      bracket,
      matches_created: matches.length
    });
  } catch (error) {
    console.error('Generate bracket error:', error);
    res.status(500).json({ detail: 'Failed to generate bracket' });
  }
});

