app.get('/api/admin/users', authenticate, requireAdmin, async (req, res) => {
  try {
    const users = await User.find().select('-_id -__v -password_hash');
    res.json(users);
  } catch (error) {
    res.status(500).json({ detail: 'Failed to fetch users' });
  }
});

app.put('/api/admin/users/:userId/role', authenticate, requireAdmin, async (req, res) => {
  try {
    const { role, team_id } = req.query;
    const validRoles = ['admin', 'manager', 'spectator'];
    if (!validRoles.includes(role)) {
      return res.status(400).json({ detail: 'Invalid role' });
    }

    const updateData = { role };
    if (team_id) updateData.team_id = team_id;

    const result = await User.updateOne({ user_id: req.params.userId }, { $set: updateData });
    if (result.matchedCount === 0) {
      return res.status(404).json({ detail: 'User not found' });
    }
    res.json({ message: 'User role updated successfully' });
  } catch (error) {
    res.status(500).json({ detail: 'Failed to update role' });
  }
});

app.delete('/api/admin/users/:userId', authenticate, requireAdmin, async (req, res) => {
  try {
    if (req.user.user_id === req.params.userId) {
      return res.status(400).json({ detail: 'Cannot delete yourself' });
    }

    const result = await User.deleteOne({ user_id: req.params.userId });
    if (result.deletedCount === 0) {
      return res.status(404).json({ detail: 'User not found' });
    }

    await Session.deleteMany({ user_id: req.params.userId });
    res.json({ message: 'User deleted successfully' });
  } catch (error) {
    res.status(500).json({ detail: 'Failed to delete user' });
  }
});

app.post('/api/admin/seed-data', authenticate, requireAdmin, async (req, res) => {
  try {
    const existingTeams = await Team.countDocuments();
    if (existingTeams > 0) {
      return res.json({ message: 'Sample data already exists', teams: existingTeams });
    }

    const teamsData = [
      { name: 'Mumbai Indians', short_name: 'MI', primary_color: '#004BA0', home_ground: 'Wankhede Stadium' },
      { name: 'Chennai Super Kings', short_name: 'CSK', primary_color: '#F9CD05', home_ground: 'MA Chidambaram Stadium' },
      { name: 'Royal Challengers', short_name: 'RCB', primary_color: '#EC1C24', home_ground: 'M. Chinnaswamy Stadium' },
      { name: 'Kolkata Knight Riders', short_name: 'KKR', primary_color: '#3A225D', home_ground: 'Eden Gardens' },
      { name: 'Delhi Capitals', short_name: 'DC', primary_color: '#0078BC', home_ground: 'Arun Jaitley Stadium' },
      { name: 'Rajasthan Royals', short_name: 'RR', primary_color: '#EA1A85', home_ground: 'Sawai Mansingh Stadium' },
      { name: 'Punjab Kings', short_name: 'PBKS', primary_color: '#ED1B24', home_ground: 'IS Bindra Stadium' },
      { name: 'Sunrisers Hyderabad', short_name: 'SRH', primary_color: '#FF822A', home_ground: 'Rajiv Gandhi Stadium' },
    ];

    const createdTeams = [];
    for (const team of teamsData) {
      const team_id = `team_${uuidv4().slice(0, 8)}`;
      const newTeam = await Team.create({
        team_id,
        ...team,
        manager_id: req.user.user_id,
        created_at: new Date()
      });
      createdTeams.push(newTeam);
    }

    // Create sample players
    const playerNames = [
      ['Rohit Sharma', 'Jasprit Bumrah', 'Hardik Pandya', 'Suryakumar Yadav', 'Ishan Kishan'],
      ['MS Dhoni', 'Ravindra Jadeja', 'Deepak Chahar', 'Ruturaj Gaikwad', 'Moeen Ali'],
      ['Virat Kohli', 'Glenn Maxwell', 'Mohammed Siraj', 'Faf du Plessis', 'Dinesh Karthik'],
      ['Shreyas Iyer', 'Andre Russell', 'Sunil Narine', 'Venkatesh Iyer', 'Nitish Rana'],
      ['Rishabh Pant', 'David Warner', 'Axar Patel', 'Prithvi Shaw', 'Anrich Nortje'],
      ['Sanju Samson', 'Jos Buttler', 'Yuzvendra Chahal', 'Shimron Hetmyer', 'Trent Boult'],
      ['Shikhar Dhawan', 'Liam Livingstone', 'Kagiso Rabada', 'Jonny Bairstow', 'Arshdeep Singh'],
      ['Kane Williamson', 'Bhuvneshwar Kumar', 'Rahul Tripathi', 'Aiden Markram', 'Umran Malik']
    ];

    const roles = ['batsman', 'bowler', 'all-rounder', 'wicket-keeper', 'batsman'];

    for (let i = 0; i < createdTeams.length; i++) {
      for (let j = 0; j < playerNames[i].length; j++) {
        const player_id = `player_${uuidv4().slice(0, 8)}`;
        await Player.create({
          player_id,
          name: playerNames[i][j],
          email: `${playerNames[i][j].toLowerCase().replace(' ', '.')}@team.com`,
          team_id: createdTeams[i].team_id,
          jersey_number: (j + 1) * 7,
          role: roles[j % 5],
          batting_style: j % 2 === 0 ? 'right-hand' : 'left-hand',
          bowling_style: roles[j % 5] !== 'batsman' ? 'right-arm fast' : null,
          matches: 15 + j * 2,
          runs: 300 + j * 80,
          balls_faced: 250 + j * 40,
          fours: 25 + j * 5,
          sixes: 12 + j * 3,
          highest_score: 85 + j * 10,
          fifties: 3 + j,
          hundreds: j === 0 ? 1 : 0,
          wickets: roles[j % 5] !== 'batsman' ? 8 + j * 2 : 0,
          balls_bowled: roles[j % 5] !== 'batsman' ? 150 + j * 20 : 0,
          runs_conceded: roles[j % 5] !== 'batsman' ? 120 + j * 15 : 0,
          best_bowling: roles[j % 5] !== 'batsman' ? `${3 + j}/25` : '0/0',
          catches: 6 + j,
          created_at: new Date()
        });
      }
    }

    res.json({
      message: 'Sample data seeded successfully',
      teams_created: createdTeams.length,
      players_created: createdTeams.length * 5
    });
  } catch (error) {
    console.error('Seed error:', error);
    res.status(500).json({ detail: 'Failed to seed data' });
  }
});

